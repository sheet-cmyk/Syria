rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Ads / listings
    match /ads/{adId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Auctions
    match /auctions/{auctionId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();

      match /bids/{bidId} {
        allow read: if true;
        allow create: if isAuth();
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    // Conversations & messages
    match /conversations/{conversationId} {
      allow read: if isAuth() && (
        resource.data.user1 == request.auth.uid ||
        resource.data.user2 == request.auth.uid
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.user1 == request.auth.uid ||
        resource.data.user2 == request.auth.uid
      );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    // Notifications
    match /notifications/{userId}/items/{notifId} {
      allow read: if isOwner(userId);
      allow write: if isAuth();
    }

    // Devices (for multi-account limit enforcement)
    match /devices/{deviceId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // Admin-only collections
    match /admin/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
